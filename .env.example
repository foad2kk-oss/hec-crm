# ── Supabase ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, used by cron/AI agent routes

# ── AI Providers (set at least one) ─────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5
AI_PROVIDER=openai   # "openai" | "anthropic" — which provider lib/ai calls use by default

# ── Web Search (used by the AI Lead Discovery agent, Module 2) ─────────
# Optional: if unset, discovery falls back to the OpenAI Responses API's
# built-in web_search tool (requires OPENAI_API_KEY).
TAVILY_API_KEY=tvly-...

# ── Google OAuth (Calendar + Gmail scopes requested at Supabase sign-in) ─
# Configure this provider inside Supabase Dashboard > Authentication > Providers > Google
# using a Google Cloud OAuth Client (Web application) with the redirect URI:
#   https://your-project-ref.supabase.co/auth/v1/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ── Cron / Edge Function auth ────────────────────────────────────────────
CRON_SECRET=generate-a-long-random-string   # checked by api/cron/* routes

# ── App ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
